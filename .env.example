# =============================================================================
# OpenCode Docker - Configuration
# =============================================================================
# Copy this file to .env and add your API key(s).
# OpenCode handles provider selection in its TUI.
# =============================================================================

# -----------------------------------------------------------------------------
# API Keys (add one or more)
# -----------------------------------------------------------------------------

# Anthropic (Claude) - https://console.anthropic.com/
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT) - https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Google Gemini - https://aistudio.google.com/app/apikey
# GEMINI_API_KEY=...

# Groq - https://console.groq.com/keys
# GROQ_API_KEY=gsk_...

# OpenRouter (75+ models) - https://openrouter.ai/keys
# OPENROUTER_API_KEY=sk-or-...

# GitHub Copilot
# GITHUB_TOKEN=ghp_...

# -----------------------------------------------------------------------------
# Local Models (Ollama)
# -----------------------------------------------------------------------------
# Run Ollama on your host, then set the port (default: 11434)
# OLLAMA_PORT=11434

# Or set the full endpoint:
# LOCAL_ENDPOINT=http://localhost:11434

# -----------------------------------------------------------------------------
# Azure OpenAI
# -----------------------------------------------------------------------------
# AZURE_OPENAI_ENDPOINT=https://myresource.openai.azure.com
# AZURE_OPENAI_API_KEY=...
# AZURE_OPENAI_API_VERSION=2024-02-15-preview

# -----------------------------------------------------------------------------
# AWS Bedrock
# -----------------------------------------------------------------------------
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Workspace
# -----------------------------------------------------------------------------
# Path to your project directory (default: ./workspace)
# WORKSPACE_PATH=./workspace
